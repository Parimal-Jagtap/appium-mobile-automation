<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">

<suite name="Mobile Automation Suite" parallel="tests" thread-count="2" verbose="1">

    <!-- Android Tests -->
    <test name="Android Tests">
        <parameter name="platform" value="android"/>
        <classes>
            <class name="tests.android.AndroidLoginTest"/>
        </classes>
    </test>

    <!-- iOS Tests -->
    <test name="iOS Tests">
        <parameter name="platform" value="ios"/>
        <classes>
            <class name="tests.ios.IOSLoginTest"/>
        </classes>
    </test>

</suite>
